{
  "rewrites": [
    { "source": "/EduCraftA/:id", "destination": "/api/redirect?id=:id&type=ambassador" },
    { "source": "/ECCA/:id",      "destination": "/api/redirect?id=:id&type=ecca" },
    { "source": "/ECSA/:id",      "destination": "/api/redirect?id=:id&type=ecsa" },
    { "source": "/register",      "destination": "/" },
    { "source": "/apply",         "destination": "/" }
  ],
  "functions": {
    "api/redirect.ts":  { "maxDuration": 10 },
    "api/register.ts":  { "maxDuration": 30 },
    "api/apply.ts":     { "maxDuration": 30 },
    "api/admin.ts":     { "maxDuration": 30 }
  },
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}
