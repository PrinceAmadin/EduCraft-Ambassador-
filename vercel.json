{
  "rewrites": [
    { "source": "/EduCraftA/:id", "destination": "/api/redirect?id=:id&type=ambassador" },
    { "source": "/ECCA/:id",      "destination": "/api/redirect?id=:id&type=ecca" },
    { "source": "/ECSA/:id",      "destination": "/api/redirect?id=:id&type=ecsa" },
    { "source": "/register",      "destination": "/" }
